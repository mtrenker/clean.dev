AUTH_SECRET="AUTH_SECRET"
GITHUB_ID="GITHUB_ID"
GITHUB_SECRET="GITHUB_SECRET"
ALLOWED_GITHUB_USERS="your-github-username"
LINKEDIN_CLIENT_ID="LINKEDIN_CLIENT_ID"
LINKEDIN_CLIENT_SECRET="LINKEDIN_CLIENT_SECRET"
DATABASE_URL="DATABASE_URL"

# SMTP Configuration for Invoice Emails
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@example.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="Your Name <your-email@example.com>"

# Review Links – Personalised Deep-Link Tokens
# Generate with: openssl rand -base64 48
REVIEW_LINK_SECRET="your-review-link-signing-secret"
# Set to "true" to enable the review-link feature (any other value disables it)
FEATURE_REVIEW_LINKS="false"
# Address that receives submitted review emails (required when FEATURE_REVIEW_LINKS=true)
REVIEW_RECIPIENT_EMAIL="your-email@example.com"
