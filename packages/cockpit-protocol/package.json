{
  "name": "@cleandev/cockpit-protocol",
  "version": "0.1.0",
  "description": "Shared cockpit protocol schemas and types for clean.dev",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./events": {
      "types": "./dist/events.d.ts",
      "default": "./dist/events.js"
    },
    "./messages": {
      "types": "./dist/messages.d.ts",
      "default": "./dist/messages.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint .",
    "test": "vitest run src/events.test.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cleandev/eslint-config": "workspace:*",
    "eslint": "^9.38.0",
    "typescript": "^5.7.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
