{
  "name": "@cleandev/db",
  "version": "0.1.0",
  "description": "Shared Drizzle schema, migrations, and migration runner for clean.dev",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./dist/schema.js"
    },
    "./migrate": {
      "types": "./dist/migrate.d.ts",
      "default": "./dist/migrate.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@cleandev/eslint-config": "workspace:*",
    "@types/node": "^22",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.2",
    "eslint": "^9.18.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
